# ==============================================================================
# AI PLAN GENERATOR CONFIGURATION
# Required for AI-powered learning plan generation
# ==============================================================================

# OpenAI API Key (for GPT-based plan generation)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Model to use (optional, defaults to gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Alternative: Use Gemini API (free tier available)
# Get one at: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=

# Alternative: Use Ollama for local AI (no API key needed)
# Install at: https://ollama.ai
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Port for the local development server (optional, defaults to 8787)
PORT=8787

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Add your Supabase credentials (already configured above)
# 3. Add your OpenAI API key for AI plan generation (optional)
# 4. Run the schema.sql in your Supabase SQL Editor
# 5. Start the server: npm run api
#
# For local development without API keys:
# - The app will use fallback/local modes
# - AI plan generation will use a simple algorithm
# - All data syncs to Supabase when configured
